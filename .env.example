# ─── MongoDB ──────────────────────────────────────────────────────────────────
MONGO_USERNAME=admin
MONGO_PASSWORD=change_me_strong_password_here
MONGO_DB=threematch

# ─── Telegram ─────────────────────────────────────────────────────────────────
# Get your token from @BotFather on Telegram
TELEGRAM_BOT_TOKEN=1234567890:ABCdefGHIjklMNOpqrSTUvwxYZ

# ─── Security ─────────────────────────────────────────────────────────────────
# Generate with:  openssl rand -hex 64
JWT_SECRET=change_me_to_at_least_64_random_chars_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ─── Server ───────────────────────────────────────────────────────────────────
# Port exposed on the host (the container always listens on :8080 internally)
APP_PORT=8080
GIN_MODE=release
